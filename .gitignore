# DistyVault .gitignore
# Optimized for a static React (UMD) + CDN project

# OS-generated files
.DS_Store
.AppleDouble
.LSOverride
Icon
._*
.Spotlight-V100
.Trashes
Thumbs.db
ehthumbs.db
Desktop.ini

# Node / JS Tooling
node_modules/
npm-debug.log*
yarn-debug.log*
package-lock.json
yarn.lock
pnpm-lock.yaml

# Agent & AI Artifacts
.gemini/
.antigravity/
.agent/
.knowledge/
knowledge/
tasks/
brain/
.system_generated/

# Build assets & caches
dist/
build/
out/
.cache/
.vite/
.vercel/

# Environment & Local Config
.env
.env.local
.env.*.local
.npmrc
.yarnrc

# Local test / temp
tmp/
temp/
.tmp/
local/
.history/